# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=cem
POSTGRES_PASSWORD=cem_secret
POSTGRES_DB=cem_db

# DATABASE_URL:
# - Interno Docker: postgresql://cem:cem_secret@postgres:5432/cem_db
# - Local Windows:  Usar 127.0.0.1 para evitar problemas de resolución en Windows
DATABASE_URL="postgresql://cem:cem_secret@127.0.0.1:5432/cem_db?schema=public"

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6379"

# ─── API / App ────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
WEB_URL=http://localhost:5173

# ─── Ollama (AI local) ────────────────────────────────────────
OLLAMA_URL="http://ollama:11434"
OLLAMA_MODEL="qwen3:4b"

# ─── Gemini (AI en la nube) ──────────────────────────────────
GEMINI_API_KEY="tu_api_key_aqui"
GEMINI_MODEL="gemini-3-flash-preview"

# ─── SMTP (alertas por email) ─────────────────────────────────
# Gmail: usa una "App Password" (https://myaccount.google.com/apppasswords)
# Otros proveedores: cambia host/port según corresponda
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# ─── Collector ────────────────────────────────────────────────
# Modo full-Docker: el collector alcanza la API por nombre de servicio
# API_URL="http://api:3001"
# Modo híbrido (API nativa + collector en Docker): usa host.docker.internal
API_URL="http://host.docker.internal:3001"
COLLECTOR_ID="kali-local"

# URL que el backend le envía al collector para que haga callback
# Modo full-Docker:        API_INTERNAL_URL=http://api:3001
# Modo híbrido (default):  API_INTERNAL_URL=http://host.docker.internal:3001
API_INTERNAL_URL="http://host.docker.internal:3001"
COLLECTOR_URL="http://localhost:5000"

# --- CONFIGURACIÓN DEL FRONTEND (React + Vite) ---
# Nota: VITE_ necesita este prefijo para ser expuesto al navegador
VITE_API_URL="http://localhost:3001"

# Opcionales para herramientas específicas
# GOBUSTER_WORDLIST="/usr/share/wordlists/dirb/common.txt"
# FFUF_WORDLIST="/usr/share/wordlists/dirb/common.txt"