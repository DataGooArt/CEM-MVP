# --- CONFIGURACIÓN DEL BACKEND (NestJS) ---
PORT=3001
NODE_ENV=development

# Base de Datos (PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cem_db?schema=public"

# Colas de Tareas y Caché (Redis)
REDIS_URL="redis://redis:6379"

# --- PROVEEDORES DE IA (Generación de Informes) ---
# Google Gemini (Principal)
GEMINI_API_KEY="tu_api_key_de_google_ai_studio_aqui"
GEMINI_REPORT_MODEL="gemini-2.0-flash"

# Ollama (Fallback local)
OLLAMA_URL="http://ollama:11434"
OLLAMA_REPORT_MODEL="qwen3:4b"

# --- CONFIGURACIÓN DEL FRONTEND (React + Vite) ---
VITE_API_URL="http://localhost:3001"

# --- CONFIGURACIÓN DEL COLLECTOR (Kali Scripts) ---
CEM_API="http://localhost:3001"
COLLECTOR_ID="kali-local"

# Opcionales para herramientas específicas
# GOBUSTER_WORDLIST="/usr/share/wordlists/dirb/common.txt"
# FFUF_WORDLIST="/usr/share/wordlists/dirb/common.txt"