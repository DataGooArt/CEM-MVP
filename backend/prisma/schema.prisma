generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  legalName            String?  @map("legal_name")
  nit                  String?
  sector               String?
  address              String?
  city                 String?
  country              String?  @default("Colombia")
  phone                String?
  contactEmail         String?  @map("contact_email")
  logoUrl              String?  @map("logo_url")
  subscriptionPlan     String   @default("FREE") @map("subscription_plan") // FREE | PRO | ENTERPRISE
  notificationSettings Json?    @default("{}") @map("notification_settings")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  assets               Asset[]
  users                User[]
  roles                Role[]
  @@map("organizations")
}

// ─── Auth & Users ─────────────────────────────────────────────────────────────
model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String         @map("password_hash")
  name           String
  organizationId String         @map("organization_id")
  roleId         String?        @map("role_id")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
  refreshTokens  RefreshToken[]
  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Role {
  id             String       @id @default(cuid())
  name           String
  organizationId String?      @map("organization_id")  // null = rol global del sistema
  permissions    String[]     @default([])
  isDefault      Boolean      @default(false) @map("is_default")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  @@index([organizationId])
  @@map("roles")
}

model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique @map("token_hash") // SHA-256 del token
  userId     String    @map("user_id")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("refresh_tokens")
}

model Asset {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  domain         String?
  ip             String?
  assetType      String      @map("asset_type")
  criticality    String      @default("MEDIUM")
  exposureScore  Float       @default(0) @map("exposure_score")
  firstSeen      DateTime    @default(now()) @map("first_seen")
  lastSeen       DateTime    @updatedAt @map("last_seen")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findings       Finding[]
  @@index([organizationId])
  @@map("assets")
}

model Finding {
  id          String      @id @default(cuid())
  assetId     String      @map("asset_id")
  category    String
  severity    String
  title       String
  description String?
  evidence    Json?       @default("{}")
  sourceTool  String      @map("source_tool")
  rawOutput   String?     @map("raw_output")
  cve         String?
  cvss        Float?
  status      String      @default("OPEN")
  createdAt   DateTime    @default(now()) @map("created_at")
  resolvedAt  DateTime?   @map("resolved_at")
  remediationStatus    String?   @map("remediation_status")
  remediationStartDate DateTime? @map("remediation_start_date")
  remediationEndDate   DateTime? @map("remediation_end_date")
  responsible          String?   @map("responsible")
  postAnalysisDate     DateTime? @map("post_analysis_date")
  closingDate          DateTime? @map("closing_date")
  remediationEvidence  String?   @map("remediation_evidence")
  closingNotes         String?   @map("closing_notes")
  archivedAt           DateTime? @map("archived_at")
  // ─── Deduplication ───────────────────────────────────────────
  contentHash          String?   @map("content_hash")              // SHA-256(assetId|category|title|sourceTool)
  seenCount            Int       @default(1) @map("seen_count")    // incremented on each duplicate ingest within same open lifecycle
  lastSeenAt           DateTime? @map("last_seen_at")              // updated every time the same finding reappears
  recurrenceCount      Int       @default(0) @map("recurrence_count") // incremented each time finding is re-opened after being closed/fixed
  // ─── Scan correlation ────────────────────────────────────────
  scanId               String?   @map("scan_id")               // scanId of the LAST scan that detected this
  firstScanId          String?   @map("first_scan_id")         // scanId of the FIRST scan that detected this
  // ─── Manual / External source ────────────────────────────────────────────
  source               String    @default("SCAN")            // SCAN | PENTEST | COMPLIANCE | BUG_BOUNTY | INTERNAL | EXTERNAL_CLIENT
  isManual             Boolean   @default(false) @map("is_manual")
  evidenceFiles        Json?     @default("[]") @map("evidence_files")   // array of stored file paths
  asset       Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  aiAnalysis  AiAnalysis?
  @@index([assetId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@index([archivedAt])
  @@unique([assetId, contentHash])                              // DB-level uniqueness; NULL contentHash is exempt
  @@map("findings")
}

model AiAnalysis {
  id              String   @id @default(cuid())
  findingId       String   @unique @map("finding_id")
  summary         String
  riskLevel       String   @map("risk_level")
  remediation     String
  businessImpact  String?  @map("business_impact")
  remediationPlan Json?    @map("remediation_plan")
  correlations    Json?    @map("correlations")    // [{ findingId, title, relationship, attackVector? }]
  attackVector    String?  @map("attack_vector")   // MITRE ATT&CK tactic if identified
  model           String   @default("llama3.2")
  createdAt       DateTime @default(now()) @map("created_at")
  finding         Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  @@map("ai_analyses")
}

model MonitoredDomain {
  id          String    @id @default(cuid())
  domain      String    @unique
  orgId       String    @default("org_demo") @map("org_id")
  tools       String[]  @default(["nmap", "nuclei"])
  cronExpr    String    @default("0 2 * * 1") @map("cron_expr")
  scanProfile String    @default("standard") @map("scan_profile")
  enabled     Boolean   @default(true)
  lastScanned DateTime? @map("last_scanned")
  nextScan    DateTime? @map("next_scan")
  createdAt   DateTime  @default(now()) @map("created_at")
  @@map("monitored_domains")
}

model ScanSession {
  id               String   @id @default(cuid())
  scanId           String   @map("scan_id")            // x-scan-id header UUID — agrupa todas las herramientas de un mismo full-scan.sh
  collectorId      String   @map("collector_id")        // x-collector-id (dominio o "kali")
  tool             String                               // nmap | nuclei | nikto | whatweb | gobuster
  orgId            String   @default("org_demo") @map("org_id")
  findingsAccepted Int      @default(0)  @map("findings_accepted")
  findingsErrors   Int      @default(0)  @map("findings_errors")
  createdAt        DateTime @default(now()) @map("created_at")
  @@index([scanId])
  @@index([collectorId])
  @@index([createdAt])
  @@map("scan_sessions")
}
// ─── Scan Job — una unidad de escaneo completa ────────────────────────────────
model ScanJob {
  id          String    @id @default(cuid())
  scanId      String    @unique @map("scan_id")
  orgId       String    @default("org_demo") @map("org_id")
  domain      String
  collectorId String    @map("collector_id")
  tools       String[]  @default([])
  status      String    @default("RUNNING")  // RUNNING | DONE | ERROR
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  @@index([orgId])
  @@index([domain])
  @@map("scan_jobs")
}

// ─── Scan Report — análisis agregado por escaneo ──────────────────────────────
model ScanReport {
  id                String   @id @default(cuid())
  scanId            String   @unique @map("scan_id")
  orgId             String   @default("org_demo") @map("org_id")
  domain            String
  collectorId       String   @map("collector_id")
  tools             String[]
  // Clasificación de hallazgos
  newFindings       Int      @default(0) @map("new_findings")       // primera vez detectados
  recurringFindings Int      @default(0) @map("recurring_findings") // ya conocidos, reconfirmados
  staleFindings     Int      @default(0) @map("stale_findings")     // abiertos pero no vistos en este scan
  totalOpen         Int      @default(0) @map("total_open")
  // Distribución por severidad
  bySeverity        Json     @default("{}") @map("by_severity")     // todos los OPEN del dominio
  newBySeverity     Json     @default("{}") @map("new_by_severity") // solo los nuevos
  // Tendencia
  riskScore         Float    @default(0) @map("risk_score")
  prevScanId        String?  @map("prev_scan_id")
  riskScoreDelta    Float    @default(0) @map("risk_score_delta")   // positivo = empeora
  durationSec       Int?     @map("duration_sec")
  createdAt         DateTime @default(now()) @map("created_at")
  @@index([orgId])
  @@index([domain])
  @@index([createdAt])
  @@map("scan_reports")
}

model AlertRule {
  id        String   @id @default(cuid())
  name      String
  severity  String[] // e.g. ["CRITICAL","HIGH"]
  channel   String   @default("email")
  target    String   // email address or webhook URL
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  @@map("alert_rules")
}

// ─── Audit Log — trazabilidad completa de cada hallazgo ──────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  type       String   // INGEST_RAW | NORMALIZED | AI_ENQUEUED | AI_ANALYZED
  findingId  String?  @map("finding_id")
  rawData    Json?    @map("raw_data")     // payload crudo del colector
  parsedData Json?    @map("parsed_data")  // hallazgo normalizado
  provider   String?                       // 'gemini' | 'ollama' (solo AI_ANALYZED)
  model      String?                       // modelo usado
  durationMs Int?     @map("duration_ms")  // ms que tardó la operación
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([type])
  @@index([findingId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TelemetryEvent {
  id        String   @id @default(cuid())
  type      String
  source    String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")
  @@index([type])
  @@index([createdAt])
  @@map("telemetry_events")
}

// ─── AI Executive Report — informe ejecutivo de pentest generado por IA ───────
model AiScanReport {
  id                 String   @id @default(cuid())
  scanId             String   @unique @map("scan_id")
  asset              String
  orgId              String   @default("org_demo") @map("org_id")
  provider           String   // gemini | ollama | fallback
  model              String
  score              Int      // 1-10 (10 = riesgo máximo)
  executiveSummary   String   @db.Text @map("executive_summary")
  technicalSummary   String   @db.Text @map("technical_summary")
  topRisks           Json     @map("top_risks")           // array de objetos
  attackSurface      Json     @map("attack_surface")      // resumen técnico estructurado
  remediationRoadmap Json     @map("remediation_roadmap") // fases immediate/shortTerm/mediumTerm
  complianceFlags    Json?    @map("compliance_flags")    // GDPR, ISO27001, PCI-DSS, etc.
  segmentedAnalysis  Json?    @map("segmented_analysis") // análisis IA segmentado por dominio (red/web/puertos/tls/secretos)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  @@index([orgId])
  @@index([createdAt])
  @@map("ai_scan_reports")
}
